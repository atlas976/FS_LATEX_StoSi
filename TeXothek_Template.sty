% 1. Boxed Formula
\newcommand{\fboxit}[2]{
  \par\vspace*{2pt}
  \begingroup
    \setlength{\fboxsep}{1.5pt}
    \colorbox{MyTurkis}{
      \begin{varwidth}{\dimexpr\linewidth-5\fboxsep\relax}
        \ensuremath{\displaystyle #1}
      \end{varwidth}
    }
    \vspace{-3pt}\raggedright\tiny #2
  \endgroup
  \par\vspace*{2pt}\noindent
} 

% 2. Compact List/Table
\newcommand{\fgridtable}[3]{
  \par\vspace*{2pt}\noindent
    {\textbf{#1:} \\
    \renewcommand{\arraystretch}{1.3}
    \setlength{\tabcolsep}{2pt}
    \begin{tabularx}{\linewidth}{|#2|}
      \hline
      #3 \\ \hline
    \end{tabularx}
    }
  \par\vspace*{2pt}\noindent
} 

% 3. Simple Alignment
\newcommand{\falign}[1]{
  \par\vspace*{2pt}\noindent\linespread{1.2}\selectfont\setlength{\lineskiplimit}{-\maxdimen}
    {$\begin{aligned}
      #1
    \end{aligned}$
    \hspace{-2pt}
    }
  \par\vspace*{2pt}\noindent
} 

\newcommand{\faligntext}[2]{%
  \par\vspace*{2pt}\noindent\linespread{1.2}\selectfont\setlength{\lineskiplimit}{-\maxdimen}
  \begin{tabularx}{\linewidth}{@{}l X@{}}
    \vspace{0pt}$\begin{aligned}[t] #1 \end{aligned}$ & 
    \vspace{0pt}\raggedright\tiny #2 
  \end{tabularx}
  \par\vspace*{2pt}\noindent
} 

% 4. Image include command
\newcommand{\fimagetext}[3]{%
  \par\vspace*{0pt}\noindent
  \begin{tabularx}{\linewidth}{@{} p{#1\linewidth} X @{}}
    \vspace{0pt}\includegraphics[width=\linewidth]{#2} & 
    \vspace{0pt}\raggedright\tiny #3 
  \end{tabularx}
  \par\vspace*{10pt}\noindent
} 

% 5. Subcolumns
\newcommand{\fsubcols}[2]{
  \par\vspace*{2pt}\noindent
  \begin{minipage}[t]{0.48\linewidth}
    \raggedright #1
  \end{minipage}%
  \hfill
  \begin{minipage}[t]{0.48\linewidth}
    \raggedright #2
  \end{minipage}
  \par\vspace*{2pt}\noindent
} 

% 6. Heading and Item commands
\newcommand{\CheatsheetItem}[3]{
  \par\vspace*{1pt}
    \item{
      \small\tiny\textbf{#1}{#2 \vspace{7pt}}{#3}
    }
  \par\vspace*{-1pt}\noindent
} 

\newcommand{\CheatsheetHeading}[2]{
  \par\vspace*{1pt}\noindent
    \begin{tabular*}{0.99\textwidth}[t]{@{}l@{\extracolsep{\fill}}r}
      {\setulcolor{MyPurple2}\color{MyPurple2}\ul{\textbf{#1}}} \textit{\color{gray}#2} \\
    \end{tabular*}
  \par\vspace*{2pt}\noindent
} 

\newcommand{\CheatsheetSubHeading}[2]{
  \par\vspace*{2pt}\noindent
    \begin{tabular*}{0.99\textwidth}[t]{@{}l@{\extracolsep{\fill}}r}
      {\setulcolor{orange}\color{orange}\ul{\tiny\textbf{#1}}} \textit{\color{gray}#2} \\
    \end{tabular*}
  \par\vspace*{2pt}\noindent
} 

\renewcommand{\labelitemi}{$\rightarrow$}

\newcommand{\CheatsheetItemListStart}{\begin{itemize}[leftmargin=*, labelsep=2.5pt, nosep]}
\newcommand{\CheatsheetItemListEnd}{\end{itemize}\vspace{-5pt}}

% 7. New bullet point
\newcommand\sbullet[1][.6]{\mathbin{\vcenter{\hbox{\scalebox{#1}{$\bullet$}}}}\hspace{2pt}}

